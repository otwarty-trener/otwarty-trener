{
  "name": "ceidg-sync",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create ceidg-leads",
    "db:migrate:local": "wrangler d1 migrations apply ceidg-leads --local",
    "db:migrate:remote": "wrangler d1 migrations apply ceidg-leads --remote",
    "kv:create": "wrangler kv namespace create CACHE",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "typescript": "^5.6.0",
    "wrangler": "^3.90.0"
  }
}
